# ── Server ───────────────────────────────────────────────────────────────
PORT=3000

# ── Supabase ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── WhatsApp Cloud API (Meta) ────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Arbitrary string you choose — must match the value in the Meta App Dashboard
WHATSAPP_VERIFY_TOKEN=bizbot-verify-token
# Meta App Secret — for X-Hub-Signature-256 webhook verification (leave blank locally)
WHATSAPP_APP_SECRET=

# ── Anthropic ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Yoco (optional — enables payment links on invoices) ──────────────────
# Get your secret key from https://dashboard.yoco.com/developers
YOCO_SECRET_KEY=

# ── General ──────────────────────────────────────────────────────────────
DEFAULT_TIMEZONE=Africa/Johannesburg
