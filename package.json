    "node-cron": "^4.2.1",
    "pdfkit": "^0.19.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/form-data": "^2.2.1",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
